<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">

    <!-- 🔥 Glass premium effect -->
    <gradient
        android:angle="270"
        android:startColor="#55FFFFFF"
        android:centerColor="#35FFFFFF"
        android:endColor="#18FFFFFF" />

    <!-- ✨ Soft border -->
    <stroke
        android:width="1dp"
        android:color="#60FFFFFF" />

    <!-- 🌟 Premium padding feel -->
    <padding
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp" />

    <!-- 💎 Smooth round -->
    <corners android:radius="100dp" />

</shape>