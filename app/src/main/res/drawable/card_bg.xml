<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- boja kartice -->
    <solid android:color="#FFFFFF"/>

    <!-- zaobljeni uglovi -->
    <corners android:radius="18dp"/>

    <!-- tanki border -->
    <stroke
        android:width="1dp"
        android:color="#E0E0E0"/>

    <!-- unutrašnji padding -->
    <padding
        android:left="12dp"
        android:top="12dp"
        android:right="12dp"
        android:bottom="12dp"/>

</shape>