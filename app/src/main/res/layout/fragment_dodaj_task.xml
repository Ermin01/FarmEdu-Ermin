<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#F5F5F5"
    android:fillViewport="true"
    tools:context=".DodajTaskFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- HEADER -->
        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/bg_back_button"
                android:padding="12dp"
                android:src="@drawable/baseline_arrow_back"
                android:layout_marginEnd="12dp"
                android:scaleType="centerInside"
                app:tint="#FFFFFF" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:text="Novi zadatak"
                android:textColor="#111111"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnSacuvaj"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_green_button"
                android:paddingHorizontal="18dp"
                android:paddingVertical="8dp"
                android:text="Sačuvaj"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- NASLOV -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="Naslov"
            android:textColor="#777777"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/etNaslov"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input"
            android:hint="Unesi naslov"
            android:paddingHorizontal="18dp"
            android:textColor="#111111"
            android:textColorHint="#999999"
            android:textSize="15sp" />

        <!-- OPIS -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Opis"
            android:textColor="#777777"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/etOpis"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input"
            android:gravity="top"
            android:hint="Dodaj opis zadatka..."
            android:padding="18dp"
            android:textColor="#111111"
            android:textColorHint="#999999"
            android:textSize="15sp" />

        <!-- DATUM -->
        <LinearLayout
            android:id="@+id/layoutDatum"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_input"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:paddingHorizontal="18dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_my_calendar"
                android:tint="#888888" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:text="Datum"
                android:textColor="#222222"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/txtDatum"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Odaberi"
                android:textColor="#111111"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- VRIJEME -->
        <LinearLayout
            android:id="@+id/layoutVrijeme"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_input"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:paddingHorizontal="18dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_lock_idle_alarm"
                android:tint="#888888" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:text="Vrijeme"
                android:textColor="#222222"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/txtVrijeme"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="08:00"
                android:textColor="#111111"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- PODSJETNIK -->
        <LinearLayout
            android:id="@+id/layoutPodsjetnik"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_input"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:paddingHorizontal="18dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_dialog_info"
                android:tint="#888888" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:text="Podsjetnik"
                android:textColor="#222222"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/txtPodsjetnik"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="15 min ranije"
                android:textColor="#111111"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- PONOVI -->
        <LinearLayout
            android:id="@+id/layoutPonovi"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_input"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:paddingHorizontal="18dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_rotate"
                android:tint="#888888" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:text="Ponovi"
                android:textColor="#222222"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/txtPonovi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nikad"
                android:textColor="#111111"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- IKONICA -->
        <LinearLayout
            android:id="@+id/layoutIkonica"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_input"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:paddingHorizontal="18dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_gallery"
                android:tint="#888888" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:text="Ikonica"
                android:textColor="#222222"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/txtIkonica"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌱 Farma"
                android:textColor="#111111"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- SACUVAJ -->

    </LinearLayout>

</androidx.core.widget.NestedScrollView>