<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#F3F5F7">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="220dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/naslovnahranazivotnja"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#66000000"/>

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="42dp"
                android:layout_gravity="top|start"
                android:padding="12dp"
                android:src="@drawable/baseline_arrow_back"
                android:background="@drawable/bg_back_button"
                app:tint="#FFFFFF"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ishrana životinja"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pravilna ishrana je temelj zdravlja, rasta i produktivnosti."
                    android:textColor="#DDFFFFFF"
                    android:textSize="13sp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <!-- Zdravlje -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginEnd="16dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:background="#33FFFFFF"
                            android:padding="6dp"
                            android:src="@android:drawable/ic_menu_info_details"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Zdravlje"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:layout_marginStart="6dp"/>
                    </LinearLayout>

                    <!-- Rast -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginEnd="16dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:background="#33FFFFFF"
                            android:padding="6dp"
                            android:src="@android:drawable/ic_menu_upload"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rast"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:layout_marginStart="6dp"/>
                    </LinearLayout>

                    <!-- Produktivnost -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:background="#33FFFFFF"
                            android:padding="6dp"
                            android:src="@android:drawable/ic_menu_agenda"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Produktivnost"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:layout_marginStart="6dp"/>
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:padding="16dp"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:elevation="3dp">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="#E8F5E9"
                android:padding="12dp"
                android:src="@android:drawable/ic_menu_gallery"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Balansirana ishrana"
                    android:textStyle="bold"
                    android:textSize="16sp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Obezbijedite raznovrsnu i kvalitetnu hranu za optimalan razvoj."
                    android:textColor="#666"
                    android:textSize="13sp" />
            </LinearLayout>

            <ImageView
                android:layout_width="90dp"
                android:layout_height="60dp"
                android:src="@drawable/hranaahraana"/>

        </LinearLayout>


        <!-- NASLOV -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Osnovne smjernice"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:textColor="#222"/>



        <View
            android:layout_width="40dp"
            android:layout_height="3dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:background="#4CAF50"/>


        <!-- ROW 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp">

            <!-- CARD -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:layout_margin="6dp"
                android:padding="12dp"
                android:orientation="horizontal"
                android:background="@drawable/card_pretty"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/vrstahrane"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vrste hrane"
                        android:textStyle="bold"
                        android:textSize="14sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sijeno, koncentrati, zelena hrana."
                        android:textSize="12sp"
                        android:textColor="#777"/>
                </LinearLayout>
            </LinearLayout>

            <!-- CARD -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:layout_margin="6dp"
                android:padding="12dp"
                android:orientation="horizontal"
                android:background="@drawable/card_pretty"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/balanas"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Balans i količina"
                        android:textStyle="bold"
                        android:textSize="14sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pravilan odnos nutrijenata."
                        android:textSize="12sp"
                        android:textColor="#777"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

        <!-- ROW 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp">

            <!-- CARD -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:layout_margin="6dp"
                android:padding="12dp"
                android:orientation="horizontal"
                android:background="@drawable/card_pretty"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/icon_circle"
                    android:padding="8dp"
                    android:src="@drawable/kvalitethrana"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Voda"
                        android:textStyle="bold"
                        android:textSize="14sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Uvijek svježa i čista voda."
                        android:textSize="12sp"
                        android:textColor="#777"/>
                </LinearLayout>
            </LinearLayout>

            <!-- CARD -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:layout_margin="6dp"
                android:padding="12dp"
                android:orientation="horizontal"
                android:background="@drawable/card_pretty"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/raspored"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Raspored"
                        android:textStyle="bold"
                        android:textSize="14sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Redovno hranjenje za najbolje rezultate."
                        android:textSize="12sp"
                        android:textColor="#777"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp">

            <!-- CARD -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:layout_margin="6dp"
                android:padding="12dp"
                android:orientation="horizontal"
                android:background="@drawable/card_pretty"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/kvalitethrana"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kvalitet hrane"
                        android:textStyle="bold"
                        android:textSize="14sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Birajte kvalitetnu hranu bez plesni i nečistoća."
                        android:textSize="12sp"
                        android:textColor="#777"/>
                </LinearLayout>
            </LinearLayout>

            <!-- CARD -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:layout_margin="6dp"
                android:padding="12dp"
                android:orientation="horizontal"
                android:background="@drawable/card_pretty"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/zdravlje"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Praćenje zdravlja"
                        android:textStyle="bold"
                        android:textSize="14sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pratite stanje životinja i reagujte na vrijeme."
                        android:textSize="12sp"
                        android:textColor="#777"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

        <!-- VAŽNO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:padding="16dp"
            android:orientation="horizontal"
            android:background="#FFF3CD">

            <ImageView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:scaleType="centerInside"
                android:src="@drawable/iconerror"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Nepravilna ishrana može dovesti do bolesti i slabog rasta."
                android:textSize="13sp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>