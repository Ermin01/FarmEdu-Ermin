<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:layout_width="match_parent"
    android:layout_height="265dp"
    android:layout_margin="5dp"
    android:foreground="?android:attr/selectableItemBackground"

    app:cardCornerRadius="24dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="#0F2B1D">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- IMAGE -->
        <ImageView
            android:id="@+id/imgZivotinja"
            android:layout_width="match_parent"
            android:layout_height="185dp"
            android:scaleType="centerCrop"
            android:src="@drawable/farm_baner"/>

        <!-- DARK OVERLAY -->
        <View
            android:layout_width="match_parent"
            android:layout_height="185dp"
            android:background="#22000000"/>

        <!-- TOP ICON -->
        <androidx.cardview.widget.CardView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_margin="10dp"

            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#36593F">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="8dp"
                android:src="@drawable/icon_app_naslovna"
                app:tint="#D7FF6D"/>
        </androidx.cardview.widget.CardView>

        <!-- BOTTOM PANEL -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_alignParentBottom="true"
            android:background="#0F2B1D"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp">

            <!-- LEFT -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtNaziv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pas"
                    android:textColor="#FFFFFF"
                    android:textSize="19sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="Upravljanje životinjama"
                    android:textColor="#A9C1B2"
                    android:textSize="11sp"/>
            </LinearLayout>

            <!-- BUTTON -->
            <androidx.cardview.widget.CardView
                android:layout_width="38dp"
                android:layout_height="38dp"

                app:cardCornerRadius="19dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#355F43">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="9dp"
                    android:src="@android:drawable/ic_media_next"
                    app:tint="#D7FF6D"/>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </RelativeLayout>

</androidx.cardview.widget.CardView>