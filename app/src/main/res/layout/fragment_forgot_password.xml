<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ForgotPassword">

    <!-- 🌄 BACKGROUND -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/register_foto"/>

    <!-- 🌫️ DARK OVERLAY -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#73000000"/>

    <!-- 🔙 BACK BUTTON -->
    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:layout_marginStart="18dp"
        android:layout_marginTop="18dp"
        android:background="@drawable/bg_circle_glass"
        android:elevation="8dp"
        android:padding="9dp"
        android:src="@drawable/baseline_arrow_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#FFFFFF"/>

    <!-- 🌍 LANGUAGE BUTTON -->
    <ImageView
        android:id="@+id/btnLanguage"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="18dp"
        android:background="@drawable/bg_circle_glass"
        android:elevation="8dp"
        android:padding="9dp"
        android:src="@drawable/jezik"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#FFFFFF"/>

    <!-- ✨ MAIN CARD -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:background="@drawable/glass_card"
        android:elevation="12dp"
        android:orientation="vertical"
        android:padding="28dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 🔐 ICON -->


        <!-- TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Zaboravili ste lozinku?"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"/>

        <!-- SUBTITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:text="Unesite svoju email adresu i poslat ćemo vam link za resetovanje lozinke."
            android:textColor="#CCFFFFFF"
            android:textSize="14sp"/>

        <!-- EMAIL INPUT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginBottom="22dp"
            android:background="@drawable/bg_input_glass"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/email"
                app:tint="#FFFFFF"/>

            <EditText
                android:id="@+id/etResetEmail"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="Unesite vaš email"
                android:inputType="textEmailAddress"
                android:paddingStart="12dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#DDFFFFFF"
                android:textSize="15sp"/>

        </LinearLayout>

        <!-- SEND BUTTON -->
        <Button
            android:id="@+id/btnSendReset"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:background="@drawable/btn_glass"
            android:elevation="8dp"
            android:text="Pošalji link"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"/>

        <!-- 🌪️ LOADING SPINNER -->
        <ImageView
            android:id="@+id/loadingSpinner"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:layout_marginTop="22dp"
            android:src="@drawable/spinner_ring"
            android:visibility="gone"/>

        <!-- INFO TEXT -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="22dp"
            android:gravity="center"
            android:text="Provjerite svoj email nakon slanja zahtjeva."
            android:textColor="#BFFFFFFF"
            android:textSize="13sp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>