<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F8FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- TITLE -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Uredi objavu"
            android:textColor="#111111"
            android:textSize="24sp"
            android:textStyle="bold"/>

        <!-- PREVIEW IMAGE -->

        <ImageView
            android:id="@+id/imgPreview"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_search_modern"
            android:scaleType="centerCrop"
            android:src="@drawable/farm_baner_zivotnja"/>

        <!-- CHANGE PHOTO -->

        <LinearLayout
            android:id="@+id/btnChangePhoto"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_search_modern"
            android:gravity="center"
            android:orientation="horizontal">


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Promijeni sliku"
                android:textColor="#111111"
                android:textSize="15sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- DESCRIPTION -->

        <EditText
            android:id="@+id/etDescription"
            android:layout_width="match_parent"
            android:layout_height="170dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_search_modern"
            android:gravity="top"
            android:hint="Uredi objavu..."
            android:padding="16dp"
            android:textColor="#111111"
            android:textSize="16sp"/>

        <!-- SAVE -->

        <LinearLayout
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_green_button"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sačuvaj izmjene"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- DELETE -->

        <LinearLayout
            android:id="@+id/btnDelete"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_search_modern"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Obriši objavu"
                android:textColor="#D32F2F"
                android:textSize="16sp"
                android:textStyle="bold"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>