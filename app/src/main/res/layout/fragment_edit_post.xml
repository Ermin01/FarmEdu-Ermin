<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F7FB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- TITLE -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Uredi objavu"
            android:textColor="#111111"
            android:textSize="26sp"
            android:textStyle="bold"/>

        <!-- MAIN IMAGE -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/img1"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/dodajfotku"
                    android:scaleType="centerCrop"/>

                <ImageView
                    android:id="@+id/remove1"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="10dp"
                    android:background="@drawable/active_bg"
                    android:padding="8dp"
                    android:src="@drawable/ic_close"
                    android:tint="#FFFFFF"/>
            </FrameLayout>

        </androidx.cardview.widget.CardView>

        <!-- SMALL IMAGES -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <!-- IMAGE 2 -->

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/img2"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/dodajfotku"
                        android:scaleType="centerCrop"/>

                    <ImageView
                        android:id="@+id/remove2"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_gravity="top|end"
                        android:layout_margin="8dp"
                        android:background="@drawable/active_bg"
                        android:padding="7dp"
                        android:src="@drawable/ic_close"
                        android:tint="#FFFFFF"/>
                </FrameLayout>

            </androidx.cardview.widget.CardView>

            <!-- IMAGE 3 -->

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/img3"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/dodajfotku"
                        android:scaleType="centerCrop"/>

                    <ImageView
                        android:id="@+id/remove3"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_gravity="top|end"
                        android:layout_margin="8dp"
                        android:background="@drawable/active_bg"
                        android:padding="7dp"
                        android:src="@drawable/ic_close"
                        android:tint="#FFFFFF"/>
                </FrameLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- DESCRIPTION -->

        <EditText
            android:id="@+id/etDescription"
            android:layout_width="match_parent"
            android:layout_height="170dp"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_search_modern"
            android:gravity="top"
            android:hint="Uredi objavu..."
            android:padding="18dp"
            android:textColor="#111111"
            android:textSize="16sp"/>

        <!-- SAVE -->

        <LinearLayout
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_green_button"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sačuvaj izmjene"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- DELETE -->

        <LinearLayout
            android:id="@+id/btnDelete"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_search_modern"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Obriši objavu"
                android:textColor="#D32F2F"
                android:textSize="16sp"
                android:textStyle="bold"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>