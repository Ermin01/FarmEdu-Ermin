<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="220dp">

            <!-- IMAGE -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/stocarstvoimg"/>

            <!-- DARK GRADIENT -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_header_overlay"/>

            <!-- BACK BUTTON -->
            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="42dp"
                android:layout_gravity="top|start"
                android:padding="12dp"
                android:src="@drawable/baseline_arrow_back"
                android:background="@drawable/bg_back_button"
                app:tint="#FFFFFF"/>

            <!-- TEXT -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="20dp"
                android:layout_marginBottom="24dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stocarstvo_naslov"
                    android:textColor="#FFFFFF"
                    android:textSize="30sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/stocarstvo_opis"
                    android:textColor="#E5E7EB"
                    android:textSize="18sp"/>
            </LinearLayout>

        </FrameLayout>
        <!-- OSNOVE -->
        <LinearLayout
            android:id="@+id/cardOsnovestoca"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:background="#FFFFFF"
            android:layout_margin="8dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/kravaicona"/>

            <LinearLayout
                android:layout_width="319dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/osnove_stocarstva"

                    android:textColor="#222"
                    android:textSize="19sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/osnove_stocarstva_opis"
                    android:textColor="#666"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="›"
                android:textSize="22sp"
                android:textColor="#999"/>
        </LinearLayout>

        <!-- ŽIVOTINJE -->
        <LinearLayout
            android:id="@+id/cardZivotinje"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:background="#FFFFFF"
            android:layout_margin="8dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:scaleType="centerInside"
                android:src="@drawable/pregledzivotnja"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/vrste_zivotinja"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:textColor="#222"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/vrste_zivotinja_opis"
                    android:textSize="14sp"
                    android:textColor="#666"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="›"
                android:textSize="22sp"
                android:textColor="#999"/>
        </LinearLayout>

        <!-- ISHRANA -->
        <LinearLayout
            android:id="@+id/cardIshrana"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:background="#FFFFFF"
            android:layout_margin="8dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:scaleType="centerInside"
                android:src="@drawable/ishranazivotnja"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ishrana_zivotinja"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:textColor="#222"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Plan ishrane za zdrav rast"
                    android:textSize="14sp"
                    android:textColor="#666"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="›"
                android:textSize="22sp"
                android:textColor="#999"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardBolesti"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:background="#FFFFFF"
            android:layout_margin="8dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:scaleType="centerInside"
                android:src="@drawable/bolestizivotnja"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/bolesti_prevencija"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:textColor="#222"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/bolesti_prevencija_opis"
                    android:textSize="14sp"
                    android:textColor="#666"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="›"
                android:textSize="22sp"
                android:textColor="#999"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardSmjestaj"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:background="#FFFFFF"
            android:layout_margin="8dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/domkuca"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/smjestaj_oprema"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:textColor="#222"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/smjestaj_oprema_opis"

                    android:textSize="14sp"
                    android:textColor="#666"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="›"
                android:textSize="22sp"
                android:textColor="#999"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardProizvodnja"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:background="#FFFFFF"
            android:layout_margin="8dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/proizvodnja"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/proizvodnja_prerada"

                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:textColor="#222"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/proizvodnja_prerada_opis"
                    android:textSize="14sp"
                    android:textColor="#666"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="›"
                android:textSize="22sp"
                android:textColor="#999"/>
        </LinearLayout>
    </LinearLayout>

</ScrollView>