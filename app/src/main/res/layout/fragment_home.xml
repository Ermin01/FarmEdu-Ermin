<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7F6">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="10dp">

                <!-- TOP ROW -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">



                    <!-- LOGO TEXT -->
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="FarmEduErmin 🌿"
                        android:textColor="#9BE15D"
                        android:textSize="22sp"
                        android:textStyle="bold"/>

                    <!-- NOTIFICATION + PROFILE -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- BELL WITH BADGE -->
                        <FrameLayout
                            android:id="@+id/btnInbox"
                            android:layout_width="40dp"
                            android:layout_height="40dp">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/porukica"
                                app:tint="#000000"/>

                            <TextView
                                android:id="@+id/txtInboxBadge"
                                android:layout_width="21dp"
                                android:layout_height="wrap_content"
                                android:layout_gravity="end|top"
                                android:background="@drawable/badge_bg"
                                android:gravity="center"
                                android:text="0"
                                android:textColor="#000000"
                                android:textSize="10sp"/>

                        </FrameLayout>

                        <!-- PROFILE -->
                        <ImageView
                            android:id="@+id/profileImage"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_marginStart="10dp"
                            android:src="@drawable/user"
                            android:scaleType="centerCrop"
                            android:background="@drawable/profile_bg"
                            android:padding="2dp"/>
                    </LinearLayout>

                </LinearLayout>

                <!-- GREETING -->
                <TextView
                    android:id="@+id/tvWelcome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"

                    android:text="Dobrodošli 👋"
                    android:textColor="#000000"
                    android:textSize="18sp"
                    android:textStyle="bold"

                    android:singleLine="true"
                    android:ellipsize="end"
                    android:maxLines="1"

                    android:duplicateParentState="false"
                    android:includeFontPadding="false"

                    android:fontFamily="sans-serif-medium"/>

                <!-- SUBTEXT -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_opis"
                    android:textColor="#000000"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

            <!-- WEATHER CARD -->
            <androidx.cardview.widget.CardView
                android:id="@+id/weatherCard"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_marginStart="0dp"
                android:layout_marginTop="1dp"
                android:layout_marginEnd="1dp"
                app:cardCornerRadius="5dp"
                app:cardElevation="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <!-- BACKGROUND -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/farm_baner" />

                    <!-- WEATHER ICON -->

                    <!-- TEMPERATURE -->

                    <!-- CONDITION -->
                    <ImageView
                        android:id="@+id/weatherIcon"
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:layout_alignParentStart="true"
                        android:layout_alignParentTop="true"
                        android:layout_marginStart="9dp"
                        android:layout_marginTop="34dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/active_bg" />

                    <TextView
                        android:id="@+id/txtTemperature"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentTop="true"
                        android:layout_marginStart="15dp"
                        android:layout_marginTop="42dp"
                        android:layout_toEndOf="@id/weatherIcon"
                        android:text="20°C"
                        android:textColor="#FFFFFF"
                        android:textSize="30sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtCondition"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/txtTemperature"
                        android:layout_marginStart="14dp"
                        android:layout_toEndOf="@id/weatherIcon"
                        android:text="Sunčano"
                        android:textStyle="bold"
                        android:textColor="#DDEBFF"
                        android:textSize="14sp" />

                    <!-- LOCATION -->
                    <LinearLayout
                        android:id="@+id/locationLayout"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:layout_marginStart="14dp"
                        android:layout_toEndOf="@id/weatherIcon"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/imgCountry"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:adjustViewBounds="true"
                            android:scaleType="centerCrop"
                            android:src="@drawable/active_bg" />

                        <TextView
                            android:id="@+id/txtLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="5dp"
                            android:text="Tuzla, Bosna i Hercegovina"
                            android:textColor="#BFD7FF"
                            android:textSize="16sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <!-- DIVIDER -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="60dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="105dp"
                        android:background="#33FFFFFF" />

                    <!-- RIGHT INFO -->
                    <LinearLayout
                        android:layout_width="95dp"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:orientation="vertical">

                        <!-- HUMIDITY -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="15dp"
                                android:layout_height="15dp"
                                android:src="@drawable/sunce"
                                app:tint="#DDEBFF" />

                            <TextView
                                android:id="@+id/txtHumidity"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:text="Vlažnost 80%"
                                android:textColor="#DDEBFF"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <!-- WIND -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="15dp"
                                android:layout_height="15dp"
                                android:src="@drawable/sunny_light"
                                app:tint="#DDEBFF" />

                            <TextView
                                android:id="@+id/txtWind"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:text="Vjetar 3 km/h"
                                android:textColor="#DDEBFF"
                                android:textSize="12sp" />
                        </LinearLayout>

                    </LinearLayout>

                </RelativeLayout>

            </androidx.cardview.widget.CardView>



            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/kategorije"
                    android:textColor="#000000"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:text="@string/pogledaj_sve"

                    android:textColor="#9BE15D"
                    android:textSize="13sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>



            <!-- AI SAVJET DANA -->
            <!-- 🤖 PREMIUM AI SAVJET DANA -->
            <LinearLayout
                android:id="@+id/aiTipCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/ai_glow_bg"
                android:orientation="horizontal"
                android:padding="18dp"
                android:elevation="8dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <!-- AI AVATAR -->
                <FrameLayout
                    android:layout_width="64dp"
                    android:layout_height="64dp">

                    <!-- GLOW -->
                    <View
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="#1A9BE15D"/>

                    <!-- AVATAR -->
                    <ImageView
                        android:id="@+id/aiAvatar"
                        android:layout_width="58dp"
                        android:layout_height="58dp"
                        android:layout_gravity="center"
                        android:src="@drawable/icon_app_naslovna"
                        android:scaleType="centerCrop"/>

                    <!-- ONLINE DOT -->
                    <View
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_gravity="bottom|end"
                        android:background="@drawable/online_dot"/>

                </FrameLayout>

                <!-- CONTENT -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <!-- TITLE -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/txtAiTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🧠 AI Savjet dana"
                            android:textColor="#000000"
                            android:textSize="18sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="PRO"
                            android:textColor="#9BE15D"
                            android:textSize="11sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <!-- AI STATUS -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/online_dot"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="AI aktivan"
                            android:textColor="#8FA3AD"
                            android:textSize="11sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" • prije 2 min"
                            android:textColor="#6E7E86"
                            android:textSize="11sp"/>
                    </LinearLayout>

                    <!-- TIP -->
                    <TextView
                        android:id="@+id/txtAiTip"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:lineSpacingExtra="3dp"
                        android:text="Danas je preporučeno provjetravanje štale zbog povećane vlage."
                        android:textColor="#121212"
                        android:textSize="14sp"/>

                    <!-- CATEGORY -->


                    <!-- BUTTONS -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <!-- VOICE -->
                        <LinearLayout
                            android:id="@+id/btnVoice"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:background="#1AFFFFFF"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp">

                            <ImageView
                                android:id="@+id/imgVoice"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/volume"
                                app:tint="#9BE15D"/>

                            <TextView
                                android:id="@+id/txtVoice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/listen_text"
                                android:textColor="#9BE15D"
                                android:textSize="12sp"/>
                        </LinearLayout>

                        <!-- REFRESH -->
                        <LinearLayout
                            android:id="@+id/btnRefreshAi"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_marginStart="10dp"
                            android:background="#1AFFFFFF"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/refresh"
                                app:tint="#9BE15D"/>
                        </LinearLayout>

                        <!-- READ MORE -->
                        <TextView
                            android:id="@+id/btnReadMore"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="@string/read_more"
                            android:textColor="#9BE15D"
                            android:textSize="13sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <!-- CONFIDENCE -->
                    <TextView
                        android:id="@+id/txtAiConfidence"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Pouzdanost AI analize: 98%"
                        android:textColor="#6E7E86"
                        android:textSize="11sp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- GRID 3 KOLONE -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="3"
                android:layout_marginTop="8dp">

                <!-- CARD TEMPLATE -->
                <!-- 1 -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/povrce_naslovna"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/card_overlay"/>

                    <TextView
                        android:text="@string/povrce"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginBottom="6dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <View
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:layout_gravity="center"
                        android:background="@drawable/icon_circle_bg"/>

                    <!-- ICON -->
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_arrow_down"
                        app:tint="#9BE15D"/>

                </FrameLayout>

                <!-- 2 -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp">

                    <!-- BACKGROUND IMAGE -->
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/naslovna_img_voce"/>

                    <!-- DARK OVERLAY -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/card_overlay"/>

                    <!-- ICON BACKGROUND (KRUG) -->
                    <View
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:layout_gravity="center"
                        android:background="@drawable/icon_circle_bg"/>

                    <!-- ICON -->
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_arrow_down"
                        app:tint="#9BE15D"/>

                    <!-- TEXT -->
                    <TextView
                        android:text="@string/voce"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginBottom="6dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                </FrameLayout>

                <!-- 3 -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp">

                    <ImageView android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/zitarice_naslov"/>

                    <View android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/card_overlay"/>

                    <View
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:layout_gravity="center"
                        android:background="@drawable/icon_circle_bg"/>

                    <!-- ICON -->
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_arrow_down"
                        app:tint="#9BE15D"/>


                    <TextView
                        android:text="@string/zitarice"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginBottom="6dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </FrameLayout>

                <!-- 4 -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp">

                    <ImageView android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/makaze_za_granje"/>

                    <View android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/card_overlay"/>

                    <View
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:layout_gravity="center"
                        android:background="@drawable/icon_circle_bg"/>

                    <!-- ICON -->
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_arrow_down"
                        app:tint="#9BE15D"/>


                    <TextView
                        android:text="@string/stocarstvo"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginBottom="6dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </FrameLayout>

                <!-- 5 -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp">

                    <ImageView android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/traktor_mas"/>

                    <View android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/card_overlay"/>

                    <View
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:layout_gravity="center"
                        android:background="@drawable/icon_circle_bg"/>

                    <!-- ICON -->
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_arrow_down"
                        app:tint="#9BE15D"/>


                    <TextView
                        android:text="@string/masine"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginBottom="6dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </FrameLayout>

                <!-- 6 -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp">

                    <ImageView android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/zacinsko_naslovna"/>

                    <View android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/card_overlay"/>

                    <View
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:layout_gravity="center"
                        android:background="@drawable/icon_circle_bg"/>

                    <!-- ICON -->
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_arrow_down"
                        app:tint="#9BE15D"/>


                    <TextView
                        android:text="@string/organska_proizvodnja"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginBottom="6dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </FrameLayout>

            </GridLayout>

            <!-- BRZI PRISTUP -->
            <!-- BRZI PRISTUP HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="18dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/brzi_pristup"
                    android:textColor="#111111"
                    android:textSize="22sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_home"
                    android:textColor="#78B93D"
                    android:textSize="14sp"
                    android:textStyle="bold"/>

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="4dp"
                    android:src="@android:drawable/ic_media_next"
                    app:tint="#78B93D"/>
            </LinearLayout>

            <!-- QUICK ACCESS -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingStart="1dp"
                android:paddingEnd="10dp"
                android:layout_marginTop="14dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- CARD 1 -->
                    <LinearLayout
                        android:id="@+id/cardSavjeti"
                        android:layout_width="95dp"
                        android:layout_height="100dp"
                        android:layout_margin="6dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/quick_access_bg"
                        android:padding="10dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_menu_info_details"
                            app:tint="#84C441"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/tips_experts"
                            android:textColor="#222222"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:gravity="center"
                            android:layout_marginTop="10dp"/>
                    </LinearLayout>

                    <!-- CARD 2 -->
                    <LinearLayout
                        android:id="@+id/notes"
                        android:layout_width="95dp"
                        android:layout_height="100dp"
                        android:layout_margin="6dp"
                        android:orientation="vertical"
                        android:gravity="center"
                            android:background="@drawable/quick_access_bg"
                        android:padding="10dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/notesicon"
                            app:tint="#F5B301"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Market"
                            android:textColor="#222222"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:gravity="center"
                            android:layout_marginTop="10dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/kameralive"
                        android:layout_width="95dp"
                        android:layout_height="100dp"
                        android:layout_margin="6dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/quick_access_bg"
                        android:padding="10dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/kamera"
                            app:tint="#F5B301"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kamere"
                            android:textColor="#222222"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:gravity="center"
                            android:layout_marginTop="10dp"/>
                    </LinearLayout>

                    <!-- CARD 4 -->
                    <LinearLayout
                        android:id="@+id/cardPlaner"
                        android:layout_width="95dp"
                        android:layout_height="100dp"
                        android:layout_margin="6dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/quick_access_bg"
                        android:padding="10dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_menu_manage"
                            app:tint="#84C441"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/day_planner"
                            android:textColor="#222222"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:gravity="center"
                            android:layout_marginTop="10dp"/>
                    </LinearLayout>



                </LinearLayout>

            </HorizontalScrollView>








            <!-- POPULARNI ČLANCI HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/ic_menu_agenda"
                        app:tint="#6FAF45"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Popularni članci"
                        android:textColor="#111111"
                        android:textSize="20sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/txtPogledajSve"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pogledaj sve"
                        android:textColor="#6FAF45"
                        android:textSize="13sp"
                        android:textStyle="bold"/>

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginStart="4dp"
                        android:src="@android:drawable/ic_media_next"
                        app:tint="#6FAF45"/>

                </LinearLayout>

            </LinearLayout>

            <!-- HORIZONTAL ARTICLES -->
            <HorizontalScrollView
                android:id="@+id/horizontalArticles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/articlesContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingEnd="24dp"
                    android:clipToPadding="false"/>

            </HorizontalScrollView>

            <!-- DOTS -->
            <LinearLayout
                android:id="@+id/dotsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:orientation="horizontal">

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_margin="4dp"
                    android:background="@drawable/dot_active"/>

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_margin="4dp"
                    android:background="@drawable/dot_inactive"/>

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_margin="4dp"
                    android:background="@drawable/dot_inactive"/>

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_margin="4dp"
                    android:background="@drawable/dot_inactive"/>

            </LinearLayout>

