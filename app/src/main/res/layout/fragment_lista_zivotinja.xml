<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#081C15">

    <!-- 🔥 PREMIUM HEADER -->
    <FrameLayout
        android:id="@+id/headerContainer"
        android:layout_width="0dp"
        android:layout_height="300dp"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 🌄 IMAGE -->
        <ImageView
            android:id="@+id/headerImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/farm_baner"/>

        <!-- 🌑 DARK OVERLAY -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#96000000"/>

        <!-- ✨ GREEN EFFECT -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#2200FF66"/>

        <!-- CONTENT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingHorizontal="22dp"
            android:paddingTop="52dp">

            <!-- TOP BAR -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- LEFT -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- AVATAR -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="46dp"
                        android:layout_height="46dp"

                        app:cardCornerRadius="23dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#204634">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="10dp"
                            android:src="@drawable/icon_app_naslovna"
                            app:tint="#D7FF6D"/>
                    </androidx.cardview.widget.CardView>

                    <!-- TEXT -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Dobrodošao nazad 👋"
                            android:textColor="#D8E6DD"
                            android:textSize="12sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="FarmEdu Premium"
                            android:textColor="#FFFFFF"
                            android:textSize="17sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                </LinearLayout>

                <!-- 🔔 NOTIFICATION -->
                <FrameLayout
                    android:layout_width="50dp"
                    android:layout_height="50dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="50dp"
                        android:layout_height="50dp"

                        app:cardCornerRadius="25dp"
                        app:cardBackgroundColor="#1AFFFFFF"
                        app:cardElevation="0dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="14dp"
                            android:src="@android:drawable/ic_dialog_info"
                            app:tint="#FFFFFF"/>
                    </androidx.cardview.widget.CardView>

                    <!-- ONLINE DOT -->
                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="9dp"
                        android:layout_marginEnd="9dp"
                        android:background="#A4D84A"/>
                </FrameLayout>

            </LinearLayout>

            <!-- 🐄 TITLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:text="Životinje"
                android:textColor="#FFFFFF"
                android:textSize="36sp"
                android:textStyle="bold"/>

            <!-- SUBTITLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Izaberi kategoriju za upravljanje i evidenciju"
                android:textColor="#D4DDD7"
                android:textSize="14sp"/>

            <!-- 🔍 SEARCH ROW -->
            <LinearLayout
                android:id="@+id/searchRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- SEARCH -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="62dp"
                    android:layout_weight="1"

                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#16000000">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="18dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@android:drawable/ic_menu_search"
                            app:tint="#B7C7BE"/>

                        <EditText
                            android:id="@+id/etSearch"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:background="@android:color/transparent"
                            android:hint="Pretraži životinje..."
                            android:textColor="#FFFFFF"
                            android:textColorHint="#B7C7BE"
                            android:textSize="15sp"/>
                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- ⚙️ FILTER -->
                <androidx.cardview.widget.CardView
                    android:layout_width="62dp"
                    android:layout_height="62dp"
                    android:layout_marginStart="12dp"

                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#A4D84A">

                    <ImageButton
                        android:id="@+id/btnFilter"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:padding="17dp"
                        android:src="@android:drawable/ic_menu_sort_by_size"
                        app:tint="#173221"/>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

    <!-- 📦 RECYCLER -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerZivotinje"
        android:layout_width="0dp"
        android:layout_height="0dp"

        android:layout_marginTop="18dp"
        android:clipToPadding="false"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingBottom="120dp"

        tools:listitem="@layout/item_kategorija_zivotnje"

        app:layout_constraintTop_toBottomOf="@id/headerContainer"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>