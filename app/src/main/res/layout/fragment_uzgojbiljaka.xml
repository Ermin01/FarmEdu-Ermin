<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#F5F7F6">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 🔝 HEADER -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="180dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/uzgojbiljaka" />

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#66000000"/>

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="42dp"
                android:layout_gravity="top|start"
                android:padding="12dp"
                android:src="@drawable/baseline_arrow_back"
                android:background="@drawable/bg_back_button"
                app:tint="#FFFFFF"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_gravity="bottom|start"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/uzgoj_biljaka"
                    android:textColor="#4CAF50"
                    android:textSize="24sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/kategorije_uzgoja"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/tvHint"
                    android:layout_marginTop="8dp"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="6dp"
                    android:text="@string/trikovi"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:background="@drawable/bg_pill"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </FrameLayout>

        <!-- 🌱 POVRĆE -->
        <LinearLayout
            android:id="@+id/cardPovrce"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:layout_margin="8dp"
            android:padding="12dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/povrceicona" />

            <TextView
                android:id="@+id/tvPovrce"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/povrce"
                android:textSize="18sp"
                android:layout_marginStart="12dp"/>

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_arrow_right"/>
        </LinearLayout>

        <!-- 🌾 ŽITARICE -->
        <LinearLayout
            android:id="@+id/cardZitarice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:layout_margin="8dp"
            android:padding="12dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/zitariceicona"/>

            <TextView
                android:id="@+id/tvZitarice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/zitarice"
                android:textSize="18sp"
                android:layout_marginStart="12dp"/>

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_arrow_right"/>
        </LinearLayout>

        <!-- 🍎 VOĆE -->
        <LinearLayout
            android:id="@+id/cardVoce"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:layout_margin="8dp"
            android:padding="12dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/voceicona"/>

            <TextView
                android:id="@+id/tvVoce"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/voce"
                android:textSize="18sp"
                android:layout_marginStart="12dp"/>

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_arrow_right"/>
        </LinearLayout>

        <!-- 🌿 ZAČINSKO BILJE -->
        <LinearLayout
            android:id="@+id/cardBilje"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:layout_margin="8dp"
            android:padding="12dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/zacinskobilje"/>

            <TextView
                android:id="@+id/tvBilje"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/zacinsko_bilje"
                android:textSize="18sp"
                android:layout_marginStart="12dp"/>

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_arrow_right"/>
        </LinearLayout>

        <!-- 💡 SAVJETI -->
        <LinearLayout
            android:id="@+id/cardSavjeti"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:layout_margin="8dp"
            android:padding="12dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/savjeticon"/>

            <TextView
                android:id="@+id/tvSavjeti"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/savjeti"
                android:textSize="18sp"
                android:layout_marginStart="12dp"/>

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_arrow_right"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>