<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    android:id="@+id/rootLayout"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F4EE"
    android:orientation="vertical"
    android:focusable="true"
    android:focusableInTouchMode="true">

    <!-- TOP BAR -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="78dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingEnd="18dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@drawable/baseline_arrow_back"
            app:tint="#1E1E1E"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"/>

        <!-- PIN -->

        <ImageView
            android:id="@+id/btnPin"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="18dp"
            android:src="@android:drawable/star_big_off"
            app:tint="#555555"/>

        <!-- BOLD -->

        <ImageView
            android:id="@+id/btnBold"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="18dp"
            android:src="@android:drawable/ic_menu_edit"
            app:tint="#555555"/>

        <!-- CHECKLIST -->

        <ImageView
            android:id="@+id/btnChecklist"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="18dp"
            android:src="@drawable/checklistaicon"
            app:tint="#555555"/>

        <!-- COLOR -->

        <ImageView
            android:id="@+id/btnColor"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="18dp"
            android:src="@android:drawable/ic_menu_manage"
            app:tint="#555555"/>

        <!-- SAVE -->

        <ImageView
            android:id="@+id/btnSave"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/active_bg"
            android:padding="12dp"
            android:src="@drawable/dodajicon"
            app:tint="#FFFFFF"/>

    </LinearLayout>

    <!-- TITLE -->

    <EditText
        android:id="@+id/editTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:background="@android:color/transparent"
        android:fontFamily="sans-serif-medium"
        android:hint="Naslov"
        android:maxLines="2"
        android:textColor="#111111"
        android:textColorHint="#999999"
        android:textSize="28sp"
        android:textStyle="bold"/>

    <!-- DATE -->

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginEnd="6dp"
            android:src="@android:drawable/ic_menu_recent_history"
            app:tint="#888888"/>

        <TextView
            android:id="@+id/txtDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="20 May 2026 • 22:41"
            android:textColor="#888888"
            android:textSize="12sp"/>

    </LinearLayout>

    <!-- CONTENT -->

    <EditText
        android:id="@+id/editContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginStart="22dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="22dp"
        android:background="@android:color/transparent"
        android:fontFamily="sans-serif"
        android:gravity="top"
        android:hint="Započni pisati svoju bilješku..."
        android:lineSpacingExtra="10dp"
        android:paddingBottom="24dp"
        android:textColor="#333333"
        android:textColorHint="#B0B0B0"
        android:textCursorDrawable="@null"
        android:textSize="16sp"/>

    <!-- BOTTOM TOOLBAR -->

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="88dp"
        android:background="#FFFFFF"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="22dp"
            android:paddingEnd="22dp">

            <!-- IMAGE -->

            <LinearLayout
                android:id="@+id/layoutImage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="28dp"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/btnImage"
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:src="@android:drawable/ic_menu_gallery"
                    app:tint="#222222"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Slika"
                    android:textColor="#777777"
                    android:textSize="11sp"/>

            </LinearLayout>

            <!-- BORDER -->


            <!-- LIST -->

            <LinearLayout
                android:id="@+id/layoutFormat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="28dp"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/btnFormatList"
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:src="@drawable/listaformaticon"
                    app:tint="#222222"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Lista"
                    android:textColor="#777777"
                    android:textSize="11sp"/>

            </LinearLayout>

            <!-- PDF -->

            <LinearLayout
                android:id="@+id/layoutPdf"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="28dp"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/btnPdf"
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:src="@android:drawable/ic_menu_save"
                    app:tint="#222222"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="PDF"
                    android:textColor="#777777"
                    android:textSize="11sp"/>

            </LinearLayout>

            <!-- VOICE -->

            <LinearLayout
                android:id="@+id/layoutVoice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="28dp"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/btnVoice"
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:src="@android:drawable/ic_btn_speak_now"
                    app:tint="#222222"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Voice"
                    android:textColor="#777777"
                    android:textSize="11sp"/>

            </LinearLayout>

            <!-- DRAW -->

            <LinearLayout
                android:id="@+id/layoutDraw"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="28dp"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/btnDraw"
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:src="@android:drawable/ic_menu_crop"
                    app:tint="#222222"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Crtaj"
                    android:textColor="#777777"
                    android:textSize="11sp"/>

            </LinearLayout>

            <!-- LOCK -->

            <LinearLayout
                android:id="@+id/layoutLock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/btnLock"
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:src="@android:drawable/ic_lock_lock"
                    app:tint="#222222"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Lock"
                    android:textColor="#777777"
                    android:textSize="11sp"/>

            </LinearLayout>

        </LinearLayout>

    </HorizontalScrollView>

</LinearLayout>