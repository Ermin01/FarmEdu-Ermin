<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">
<!--    android:background="#071A12">-->


    <!-- 🌄 PREMIUM HEADER -->
    <FrameLayout
        android:id="@+id/headerContainer"
        android:layout_width="0dp"
        android:layout_height="300dp"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">



        <!-- IMAGE -->
        <ImageView
            android:id="@+id/headerImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/farm_baner"/>

        <!-- DARK OVERLAY -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#96000000"/>

        <!-- GREEN GLOW -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#2200FF66"/>

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="42dp"
            android:layout_gravity="top|start"
            android:padding="12dp"
            android:src="@drawable/baseline_arrow_back"
            android:background="@drawable/bg_back_button"
            app:tint="#FFFFFF"/>

        <!-- CONTENT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingHorizontal="22dp"
            android:paddingTop="52dp">


            <!-- TOP BAR -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- LEFT -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- AVATAR -->

                    <!-- TEXT -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical"/>

                </LinearLayout>



            </LinearLayout>

            <!-- TITLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:text="Vrste Životinja"
                android:textColor="#FFFFFF"
                android:textSize="35sp"
                android:textStyle="bold"/>

            <!-- SUBTITLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Izaberi kategoriju za upravljanje i evidenciju"
                android:textColor="#D4DDD7"
                android:textSize="16sp"/>

            <!-- 🔍 SEARCH ROW -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- SEARCH -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="62dp"
                    android:layout_weight="1"

                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#16000000">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="10dp">

                        <ImageView
                            android:layout_width="23dp"
                            android:layout_height="23dp"
                            android:src="@android:drawable/ic_menu_search"
                            app:tint="#B7C7BE"/>

                        <EditText
                            android:id="@+id/etSearch"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:background="@android:color/transparent"
                            android:hint="Pretraži životinje..."
                            android:textColor="#FFFFFF"
                            android:textColorHint="#B7C7BE"
                            android:textSize="15sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- FILTER -->
                <androidx.cardview.widget.CardView
                    android:layout_width="62dp"
                    android:layout_height="62dp"
                    android:layout_marginStart="12dp"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#22FFFFFF">

                    <ImageButton
                        android:id="@+id/btnFilter"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:padding="17dp"
                        android:src="@android:drawable/ic_menu_sort_by_size"
                        android:textColorHint="#048E40"
                        app:tint="#269E69"/>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

    <!-- 🐄 PREMIUM GRID -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerZivotinje"
        android:layout_width="0dp"
        android:layout_height="0dp"

        android:layout_marginTop="28dp"

        android:clipToPadding="false"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingBottom="120dp"

        app:layout_constraintTop_toBottomOf="@id/headerContainer"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>