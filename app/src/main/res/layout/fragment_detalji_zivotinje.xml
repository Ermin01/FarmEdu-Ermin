<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="340dp">

            <!-- SLIKA -->
            <ImageView
                android:id="@+id/imgDetalj"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/profile_bg" />

            <!-- OVERLAY -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#88000000" />

            <!-- TOP BAR -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="18dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:padding="10dp"
                    android:background="@drawable/bg_back_button"
                    android:src="@drawable/baseline_arrow_back"
                    app:tint="#FFFFFF" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="DETALJI ŽIVOTINJE"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="18sp" />

                <ImageView
                    android:id="@+id/btnFavorite"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:padding="10dp"
                    android:background="@drawable/profile_bg"
                    android:src="@android:drawable/btn_star_big_on"
                    app:tint="#FFFFFF" />

            </LinearLayout>

            <!-- INFO -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_margin="20dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtNaziv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Malinoa"
                    android:textColor="#FFFFFF"
                    android:textSize="38sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtPodnaslov"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pametan • Zaštitnički • Aktivan"
                    android:textColor="#DDDDDD"
                    android:textSize="16sp"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

        </FrameLayout>

        <!-- CONTENT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- OSNOVNE -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#161B22"
                app:cardCornerRadius="26dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/headerOsnovne"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="18dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_info_details"
                            app:tint="#F5C451" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text=" OSNOVNE INFORMACIJE"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:textSize="17sp" />

                        <ImageView
                            android:id="@+id/arrowOsnovne"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/arrow_down_float"
                            app:tint="#F5C451" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/txtOsnovne"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:paddingBottom="18dp"
                        android:textColor="#DADADA"
                        android:textSize="15sp"
                        android:lineSpacingExtra="6dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- PONASANJE -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#161B22"
                app:cardCornerRadius="26dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/headerPonasanje"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="18dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_myplaces"
                            app:tint="#F5C451" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text=" PONAŠANJE"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:textSize="17sp" />

                        <ImageView
                            android:id="@+id/arrowPonasanje"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/arrow_down_float"
                            app:tint="#F5C451" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/txtPonasanje"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:paddingBottom="18dp"
                        android:textColor="#DADADA"
                        android:textSize="15sp"
                        android:lineSpacingExtra="6dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ZDRAVLJE -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#161B22"
                app:cardCornerRadius="26dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/headerZdravlje"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="18dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_manage"
                            app:tint="#F5C451" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text=" ZDRAVLJE"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:textSize="17sp" />

                        <ImageView
                            android:id="@+id/arrowZdravlje"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/arrow_down_float"
                            app:tint="#F5C451" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/txtZdravlje"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:paddingBottom="18dp"
                        android:textColor="#DADADA"
                        android:textSize="15sp"
                        android:lineSpacingExtra="6dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ISHRANA -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#161B22"
                app:cardCornerRadius="26dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/headerIshrana"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="18dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_crop"
                            app:tint="#F5C451" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text=" ISHRANA"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:textSize="17sp" />

                        <ImageView
                            android:id="@+id/arrowIshrana"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/arrow_down_float"
                            app:tint="#F5C451" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/txtIshrana"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:paddingBottom="18dp"
                        android:textColor="#DADADA"
                        android:textSize="15sp"
                        android:lineSpacingExtra="6dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- AKTIVNOST -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#161B22"
                app:cardCornerRadius="26dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/headerAktivnost"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="18dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_media_play"
                            app:tint="#F5C451" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text=" AKTIVNOST"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:textSize="17sp" />

                        <ImageView
                            android:id="@+id/arrowAktivnost"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/arrow_down_float"
                            app:tint="#F5C451" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/txtAktivnost"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:paddingBottom="18dp"
                        android:textColor="#DADADA"
                        android:textSize="15sp"
                        android:lineSpacingExtra="6dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </LinearLayout>

</ScrollView>