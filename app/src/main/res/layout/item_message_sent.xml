<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:gravity="end"
    android:orientation="vertical">

    <!-- TIME -->

    <TextView
        android:id="@+id/txtTopTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="4dp"
        android:text="09:21"
        android:textColor="#9E9E9E"
        android:textSize="11sp" />

    <!-- MESSAGE CARD -->

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:background="@drawable/bg_overlay_gradient"
        android:elevation="2dp"
        android:maxWidth="290dp"
        android:minWidth="90dp"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="14dp"
        android:paddingBottom="10dp">

        <!-- MESSAGE -->

        <TextView
            android:id="@+id/txtMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pozdrav! Danas smo završili sadnju pšenice 🌾🚜"
            android:textColor="#1A1A1A"
            android:textSize="16sp"
            android:lineSpacingExtra="2dp" />

        <!-- BOTTOM -->

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtMessageTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="09:21"
                android:textColor="#7A7A7A"
                android:textSize="11sp" />

            <ImageView
                android:id="@+id/imgSeen"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginStart="5dp"
                android:src="@drawable/filter_active_bg" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>