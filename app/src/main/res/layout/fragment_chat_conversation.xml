<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#EEF4EA"
    tools:context=".chat.ChatConversationFragment">

    <!-- HEADER -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:background="@drawable/bg_green_button"
            android:padding="11dp"
            android:src="@drawable/baseline_arrow_back"
            app:tint="#FFFFFF" />

        <FrameLayout
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginStart="14dp">

            <ImageView
                android:id="@+id/imgUser"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/profile_circle_bg"
                android:scaleType="centerCrop"
                android:src="@drawable/user" />

            <View
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="bottom|end"
                android:layout_margin="4dp"
                android:background="@drawable/bg_online_dot" />

        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ErminHam"
                android:textColor="#111111"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/active_now"
                android:textColor="#43A047"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>

        <ImageView
            android:id="@+id/btnCall"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_green_button"
            android:padding="11dp"
            android:src="@drawable/phone"
            app:tint="#FFFFFF" />

        <ImageView
            android:id="@+id/btnMore"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_green_button"
            android:padding="11dp"
            android:src="@drawable/postavke"
            app:tint="#FFFFFF" />

    </LinearLayout>

    <!-- CHAT -->

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0.05"
            android:scaleType="centerCrop"
            android:src="@drawable/povrce_naslovna" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerMessages"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="14dp"
            tools:listitem="@layout/item_message_sent" />

    </FrameLayout>

    <!-- INPUT -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="18dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingTop="10dp"
        android:paddingEnd="12dp"
        android:paddingBottom="14dp">

        <ImageView
            android:id="@+id/btnAttach"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/bg_green_button"
            android:padding="12dp"
            android:src="@drawable/camera"
            app:tint="#FFFFFF" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:background="@drawable/bg_search_modern"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="14dp">

            <androidx.appcompat.widget.AppCompatEditText
                android:id="@+id/etMessage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="@string/send_message_hint"
                android:imeOptions="actionSend"
                android:inputType="textMultiLine"
                android:maxLines="4"
                android:textColor="#111111"
                android:textColorHint="#9E9E9E"
                android:textSize="15sp" />

            <ImageView
                android:id="@+id/btnEmoji"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_marginStart="8dp"
                android:src="@android:drawable/btn_star_big_on"
                app:tint="#66BB6A" />

        </LinearLayout>

        <ImageView
            android:id="@+id/btnSend"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_green_button"
            android:padding="15dp"
            android:src="@drawable/send"
            app:tint="#FFFFFF" />

    </LinearLayout>

</LinearLayout>